{
    "name": "template-mcp-ts",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "license": "Apache-2.0",
    "author": {
        "name": "concertypin",
        "url": "https://github.com/concertypin"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/templecon/template-mcp-ts"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "format": "prettier --write . --cache --cache-location node_modules/.cache/prettier --list-different",
        "lint": "pnpm run lint:check --fix",
        "lint:check": "oxlint .",
        "postinstall": "pnpm run cf-typegen && simple-git-hooks",
        "check": "pnpm run format && pnpm run lint && pnpm run test && git add -u",
        "pre-commit": "pnpm run check",
        "test": "node scripts/vitest.ts run",
        "deploy": "pnpm run build && wrangler deploy",
        "inspect": "node scripts/inspect.ts",
        "e2e:inspector": "node scripts/e2e-inspector.ts"
    },
    "engines": {
        "node": ">=22.18.0 <23.0.0 || >=23.6.0"
    },
    "dependencies": {
        "@hono/mcp": "^0.3.0",
        "@hono/standard-validator": "^0.2.2",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@scalar/hono-api-reference": "^0.10.16",
        "hono": "^4.12.19",
        "hono-openapi": "^1.3.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.37.1",
        "@cloudflare/vitest-pool-workers": "^0.16.6",
        "@types/node": "^25.8.0",
        "@vitest/coverage-istanbul": "^4.1.6",
        "cross-env": "^10.1.0",
        "oxlint": "^1.66.0",
        "oxlint-tsgolint": "^0.22.1",
        "prettier": "^3.8.3",
        "simple-git-hooks": "^2.13.1",
        "typescript": "~6.0.3",
        "vite": "^8.0.13",
        "vitest": "^4.1.6",
        "wrangler": "^4.92.0"
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
